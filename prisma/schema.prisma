generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VotingMethod {
  RCV
  CONDORCET
  STAR
}

enum PollStatus {
  DRAFT
  OPEN
  CLOSED
}

enum EmailTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum AuthProvider {
  EMAIL_PASSWORD
  PASSKEY
}

enum AuthChallengeKind {
  PASSKEY_REGISTER
  PASSKEY_LOGIN
}

model User {
  id              String        @id @default(uuid())
  email           String?       @unique
  passwordHash    String?
  displayName     String        @default("Anonymous User")
  emailVerifiedAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sessions        Session[]
  accounts        AuthAccount[]
  polls           Poll[]
  emailTokens     EmailToken[]
  authChallenges  AuthChallenge[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAccount {
  id                   String       @id @default(uuid())
  userId               String
  provider             AuthProvider
  providerAccountId    String
  credentialPublicKey  Bytes?
  counter              Int?
  transports           String?
  aaguid               String?
  createdAt            DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthChallenge {
  id         String            @id @default(uuid())
  userId     String?
  kind       AuthChallengeKind
  tokenHash  String            @unique
  expiresAt  DateTime
  createdAt  DateTime          @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([kind])
}

model Poll {
  id                        String        @id @default(uuid())
  publicId                  String        @unique
  creatorId                 String
  title                     String
  description               String
  method                    VotingMethod
  status                    PollStatus    @default(DRAFT)
  maxVoters                 Int
  requireVoterName          Boolean       @default(false)
  showVoterNamesInResults   Boolean       @default(false)
  showNameToBallotMapping   Boolean       @default(false)
  seedForTiebreak           String
  opensAt                   DateTime?
  closesAt                  DateTime?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  creator       User                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  options       PollOption[]
  votes         Vote[]
  voterSessions PollVoterSession[]
  snapshots     PollResultsSnapshot[]
}

model PollOption {
  id         String   @id @default(uuid())
  pollId     String
  label      String
  orderIndex Int

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, orderIndex])
}

model PollVoterSession {
  id            String   @id @default(uuid())
  pollId        String
  tokenHash     String
  votedAt       DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, tokenHash])
}

model Vote {
  id                 String   @id @default(uuid())
  pollId             String
  pollVoterSessionId String
  voterName          String?
  createdAt          DateTime @default(now())

  poll          Poll                @relation(fields: [pollId], references: [id], onDelete: Cascade)
  rankedEntries RankedBallotEntry[]
  starScores    StarBallotScore[]

  @@unique([pollId, pollVoterSessionId])
}

model RankedBallotEntry {
  id       String @id @default(uuid())
  voteId   String
  optionId String
  rank     Int

  vote Vote @relation(fields: [voteId], references: [id], onDelete: Cascade)

  @@unique([voteId, rank])
}

model StarBallotScore {
  id       String @id @default(uuid())
  voteId   String
  optionId String
  score    Int

  vote Vote @relation(fields: [voteId], references: [id], onDelete: Cascade)

  @@unique([voteId, optionId])
}

model PollResultsSnapshot {
  id          String   @id @default(uuid())
  pollId      String
  computedAt  DateTime @default(now())
  payloadJson Json

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
}

model EmailToken {
  id         String        @id @default(uuid())
  userId     String
  type       EmailTokenType
  tokenHash  String        @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
