{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@ballot/shared/*": ["packages/shared/src/*"],
      "@ballot/voting-engine/*": ["packages/voting-engine/src/*"],
      "@ballot/shared": ["packages/shared/src/index"],
      "@ballot/voting-engine": ["packages/voting-engine/src/index"]
    }
  }
}
