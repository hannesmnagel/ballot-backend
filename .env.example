# Database
DATABASE_URL=postgresql://ballot:ballot@db:5432/ballot?schema=public

# Auth & Security
# For local development:
BETTER_AUTH_URL=http://localhost:3000
# For production, use:
# BETTER_AUTH_URL=https://ballot.hannesnagel.com

# Email (SMTP)
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=your-email@icloud.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=contact@hannesnagel.com

# Passkey/WebAuthn
# For local development:
PASSKEY_RP_ID=localhost
PASSKEY_ORIGIN=http://localhost:3000
# For production, use:
# PASSKEY_RP_ID=ballot.hannesnagel.com
# PASSKEY_ORIGIN=https://ballot.hannesnagel.com
