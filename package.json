{
  "name": "ballot-backend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ballot/web",
    "build": "npm run build -w @ballot/web",
    "start": "npm run start -w @ballot/web",
    "test": "npm run test -w @ballot/web && npm run test -w @ballot/voting-engine",
    "lint": "npm run lint -w @ballot/web",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "typescript": "^5.7.3"
  }
}
